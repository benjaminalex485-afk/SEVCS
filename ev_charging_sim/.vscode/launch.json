{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask Mock Server",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/mock_server.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "FLASK_APP": "mock_server.py",
                "FLASK_ENV": "development"
            }
        }
    ]
}
